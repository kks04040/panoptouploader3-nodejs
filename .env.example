# ===== Panopto 접속 정보 =====
# Panopto 사이트 URL (예: https://[site].hosted.panopto.com)
PANOPTO_SITE_URL=

# OAuth2 Client Credentials
PANOPTO_CLIENT_ID=
PANOPTO_CLIENT_SECRET=

# 서비스 계정 (폴더 생성/권한 부여용 관리자급 계정)
PANOPTO_SERVICE_ACCOUNT_USER=
PANOPTO_SERVICE_ACCOUNT_PASSWORD=

# Users 최상위 폴더 ID
PANOPTO_USERS_PARENT_FOLDER_ID=

# 파놉토 연결 엔터티 ID (user 폴더명 접두사, 예: cup-panopto)
PANOPTO_LINK_ENTITY_ID=

# ===== Linux 서버 (원본 동영상) 접속 정보 =====
# 파일 접근 방식: LOCAL_MOUNT | SFTP
LINUX_FILE_ACCESS_MODE=LOCAL_MOUNT

# SFTP 사용 시
LINUX_SFTP_HOST=
LINUX_SFTP_PORT=22
LINUX_SFTP_USER=
LINUX_SFTP_PASSWORD=
LINUX_SFTP_PRIVATE_KEY_PATH=

# 원본 동영상 루트 경로 (마운트 포인트 또는 SFTP 기준 경로)
LINUX_SOURCE_ROOT_PATH=

# ===== Database (Oracle) 접속 정보 =====
DB_HOST=
DB_PORT=1521
DB_SERVICE_NAME=
DB_USER=
DB_PASSWORD=

# ===== 업로드 설정 =====
# 청크 업로드 크기 (MB)
UPLOAD_CHUNK_SIZE_MB=10
# 인코딩 완료 폴링 주기 (초)
POLLING_INTERVAL_SEC=10
# 최대 폴링 대기 시간 (초)
POLLING_TIMEOUT_SEC=3600
# 최대 재시도 횟수
MAX_RETRY_COUNT=3
# 배치 처리 건수
BATCH_SIZE=50

# ===== 기타 =====
# 파놉토 폴더명 구분자 (Panopto 기본: 백슬래시 \, 허용 안 될 경우 _ 로 변경)
# 주의: 단일 \ 한 개로 작성 (dotenv는 이스케이프 처리하지 않음)
FOLDER_NAME_DELIMITER=\
# 로그 레벨 (debug | info | warn | error)
LOG_LEVEL=info
